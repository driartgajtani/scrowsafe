# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/escrowsafe

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Encryption key for sensitive fields (credentials, bank info)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Tidio (optional webhook logging)
TIDIO_PUBLIC_KEY=your_tidio_public_key

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:4200

# Set to "true" to require email verification on registration (needs working SMTP)
REQUIRE_EMAIL_VERIFICATION=false

# SMTP (email service for password reset etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=Scrowsafe <noreply@scrowsafe.com>

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
